  "glossary": [
    {
      "id": "g1",
      "type": "Auto",
      "event": "page_view",
      "definition": "each time the page loads or the browser history state is changed by the active site",
      "parameter": "page_location (collected by GA4)",
      "value": "(page URL)",
      "note": "Use this event to replace \"impression\"",
      "resource": ""
    },
    {
      "id": "g2",
      "type": "Auto",
      "event": "file_download",
      "definition": "when a user clicks a link leading to a file (with a common file extension) of the following types: document, text, executable, presentation, compressed file, video, audio",
      "parameter": "file_extension, file_name, link_classes, link_domain, link_id, link_text, link_url (collected by GA4)",
      "value": "(file name)",
      "note": "*Need to check if all downloader file name is different (or file URL)",
      "resource": ""
    },
    {
      "id": "g3",
      "type": "Custom",
      "event": "page_view_cust",
      "definition": "each time the page or popup loads or shows",
      "parameter": "inbound_popup",
      "value": "Purchase_Popup\nCombo_Popup\n!Purchase_Popup_New",
      "note": "this event seems to be more for the popup, should just change the name",
      "resource": ""
    },
    {
      "id": "g4",
      "type": "Custom",
      "event": "page_view_cust",
      "definition": "",
      "parameter": "product",
      "value": "DirectorSuite\nPowerDirector\nPowerDirectorMac\nPowerDirectorBusiness\nPromeo\nPromeoApp\nPhotoDirector\nPhotoDirectorMac\nPhotoDirectorApp\nAudioDirector\nColorDirector\nYouCam\nPowerPlayer\nPerfectCam\nPowerDirector_Ultimate",
      "note": "*PDR Ultimate is for Combo_Popup",
      "resource": ""
    },
    {
      "id": "g5",
      "type": "Custom",
      "event": "page_view_cust",
      "definition": "",
      "parameter": "click_point",
      "value": "Top_Banner\nBottom_Banner\nSticky_Header\n!In_Page\nSticky_Footer\nFloating\n!Direct",
      "note": "\"Direct\" parameter value is for those who landed on the popup directly",
      "resource": ""
    },
    {
      "id": "g6",
      "type": "Custom",
      "event": "inbound_click_buy_button",
      "definition": "Inbound click (click on buttons within the domain) on buy buttons and open popup (for 365) or direct to shopping cart (for perpetual)",
      "parameter": "click_point",
      "value": "Top_Banner\nBottom_Banner\nSticky_Header\n!In_Page_(section name)\nSticky_Footer\nFloating",
      "note": "*in_body change to in_page since there is also CTA button in product page. Buttons on Store page will also be categorized in this parameter value",
      "resource": ""
    },
    {
      "id": "g7",
      "type": "Custom",
      "event": "inbound_click_buy_button",
      "definition": "",
      "parameter": "page_location (collected by GA4)",
      "value": "(page URL)",
      "note": "",
      "resource": ""
    }
  ]
